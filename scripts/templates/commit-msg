#!/bin/bash
# Commit message hook - enforces Conventional Commits format
# See: https://www.conventionalcommits.org/

set -e

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Allow empty commit messages (for squash/fixup)
if [ -z "$COMMIT_MSG" ] || [[ "$COMMIT_MSG" =~ ^(squash|fixup)! ]]; then
    exit 0
fi

# Conventional Commits regex
# Format: type(scope?): description
# Types: feat, fix, build, chore, ci, docs, style, refactor, perf, test
CONV_COMMIT_REGEX='^(feat|fix|build|chore|ci|docs|style|refactor|perf|test|revert)(\([a-z0-9-]+\))?: .{10,}'

if [[ "$COMMIT_MSG" =~ $CONV_COMMIT_REGEX ]]; then
    echo -e "${GREEN}✓ Commit message follows Conventional Commits format${NC}"
    exit 0
fi

# Check for WIP commits (allowed)
if [[ "$COMMIT_MSG" =~ ^(WIP|wip|WIP!): ]]; then
    echo -e "${YELLOW}⚠ WIP commit (fine for work-in-progress)${NC}"
    exit 0
fi

# If we get here, the commit message doesn't follow convention
echo ""
echo -e "${RED}❌ Invalid commit message format${NC}"
echo ""
echo "Your commit message must follow Conventional Commits:"
echo ""
echo "  type(scope): description"
echo ""
echo "Types:"
echo "  feat     - New feature"
echo "  fix      - Bug fix"
echo "  docs     - Documentation changes"
echo "  style    - Formatting, missing semicolons, etc. (no code change)"
echo "  refactor - Code restructuring (no feature/bug change)"
echo "  perf     - Performance improvement"
echo "  test     - Adding or fixing tests"
echo "  build    - Build system changes"
echo "  chore    - Other changes (tooling, config, etc.)"
echo "  ci       - CI/CD changes"
echo "  revert   - Revert a previous commit"
echo ""
echo "Examples:"
echo "  feat(auth): add password reset endpoint"
echo "  fix(api): correct pagination offset calculation"
echo "  docs(readme): add deployment instructions"
echo "  chore: update dependencies"
echo ""
echo "Your message:"
echo "  $COMMIT_MSG"
echo ""
echo "To skip this check (NOT recommended), use:"
echo "  git commit --no-verify"
echo ""
echo "Or edit your message:"
echo "  git commit --edit -m \"type(scope): your message\""
echo ""

exit 1
