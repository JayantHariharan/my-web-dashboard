#!/bin/bash
# Pre-merge hook - blocks local merges involving protected branches (main/develop)
# Enforces PR-based workflow for protected branches

set -e

echo "🔍 Running pre-merge checks..."

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Get current branch (target of the merge)
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Check if a merge is in progress
if git rev-parse --verify MERGE_HEAD >/dev/null 2>&1; then
    MERGE_COMMIT=$(git rev-parse MERGE_HEAD)

    # Determine source branches containing this commit (the branch being merged)
    MERGE_BRANCHES=$(git branch --contains "$MERGE_COMMIT" 2>/dev/null | sed 's/^* //; s/^  //')

    SOURCE_IS_PROTECTED=0
    if echo "$MERGE_BRANCHES" | grep -q -E '^(main|develop)$'; then
        SOURCE_IS_PROTECTED=1
    fi

    TARGET_IS_PROTECTED=0
    if [[ "$CURRENT_BRANCH" =~ ^(main|develop)$ ]]; then
        TARGET_IS_PROTECTED=1
    fi

    if [ $SOURCE_IS_PROTECTED -eq 1 ] || [ $TARGET_IS_PROTECTED -eq 1 ]; then
        echo -e "${RED}❌ Merge blocked: protected branch involvement${NC}"
        if [ $TARGET_IS_PROTECTED -eq 1 ]; then
            echo "   Target branch '$CURRENT_BRANCH' is protected."
        fi
        if [ $SOURCE_IS_PROTECTED -eq 1 ]; then
            echo "   Source branch is protected (main/develop)."
        fi
        echo ""
        echo "Local merges into/from protected branches are not allowed."
        echo "Use GitHub PRs to merge changes (they run CI/CD and enforce reviews)."
        echo ""
        echo "If you need changes from a protected branch, use rebase instead:"
        echo "  git pull --rebase origin $CURRENT_BRANCH"
        echo ""
        echo "To create a PR, push your branch and open a PR on GitHub."
        exit 1
    fi
fi

# Merge allowed (doesn't involve protected branches)
exit 0
