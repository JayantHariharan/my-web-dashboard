#!/bin/bash
set -e

echo "🔍 Running pre-commit quality checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Use ASCII fallbacks on Windows if needed (avoid Unicode errors)
if command -v uname &> /dev/null && uname | grep -i windows &> /dev/null; then
    CHECK_MARK="[PASS]"
    WARN_MARK="[WARN]"
    FAIL_MARK="[FAIL]"
else
    CHECK_MARK="[PASS]"
    WARN_MARK="[WARN]"
    FAIL_MARK="[FAIL]"
fi

FAIL=0

# 1. Python syntax check
echo -n "  Python syntax... "
python -m py_compile src/backend/main.py 2>/dev/null && echo -e "${GREEN}[PASS]${NC}" || {
    echo -e "${RED}[FAIL] Syntax error${NC}"
    FAIL=1
}

# 2. Black format check (fast)
echo -n "  Code formatting... "
if command -v black &> /dev/null; then
    black --check src/backend/ 2>/dev/null && echo -e "${GREEN}[PASS]${NC}" || {
        echo -e "${RED}[FAIL] Code not formatted${NC}"
        echo "    Run: black src/backend/"
        FAIL=1
    }
else
    echo -e "${YELLOW}[WARN] (black not installed)${NC}"
fi

# 3. Flake8 critical errors
echo -n "  Linting (critical)... "
if command -v flake8 &> /dev/null; then
    if flake8 src/backend/ --count --select=E9,F63,F7,F82 --isolated > /dev/null 2>&1; then
        echo -e "${GREEN}[PASS]${NC}"
    else
        echo -e "${RED}[FAIL] Critical lint errors${NC}"
        flake8 src/backend/ --count --select=E9,F63,F7,F82 --show-source --isolated || true
        FAIL=1
    fi
else
    echo -e "${YELLOW}[WARN] (flake8 not installed)${NC}"
fi

# 4. Check for secrets (simple patterns)
echo -n "  Hardcoded secrets... "
if grep -rn "SECRET_KEY\s*=" src/backend/ --include="*.py" \
    | grep -v "os.environ.get" \
    | grep -v "from os import" \
    > /dev/null 2>&1; then
    echo -e "${RED}[FAIL] Potential hardcoded secret${NC}"
    grep -rn "SECRET_KEY\s*=" src/backend/ --include="*.py" \
        | grep -v "os.environ.get" \
        | grep -v "from os import" || true
    FAIL=1
else
    echo -e "${GREEN}[PASS]${NC}"
fi

# 5. Check for TODO/FIXME in committed files
echo -n "  No TODO/FIXME in commits... "
STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
if [ -n "$STAGED_PY_FILES" ]; then
    # Use -w for word match to avoid false positives (e.g., "DEBUG" matching "BUG")
    if echo "$STAGED_PY_FILES" | xargs grep -lw -E "TODO|FIXME|BUG|HACK" 2>/dev/null > /dev/null; then
        echo -e "${YELLOW}[WARN] TODO/FIXME found${NC}"
        echo "$STAGED_PY_FILES" | xargs grep -nw -E "TODO|FIXME|BUG|HACK" || true
        echo "    Consider addressing or create issue for tracking."
    else
        echo -e "${GREEN}[PASS]${NC}"
    fi
else
    echo -e "${GREEN}[PASS]${NC}"
fi

# 6. Workflow validation (concurrency, retention)
echo -n "  Validating workflow files... "
if command -v python3 &> /dev/null; then
    # Get staged workflow files
    STAGED_WORKFLOWS=$(git diff --cached --name-only --diff-filter=ACM | grep '^\.github/workflows/.*\.yml$' || true)

    if [ -n "$STAGED_WORKFLOWS" ]; then
        VALIDATION_FAIL=0
        # Convert newlines to spaces to pass as separate arguments
        STAGED_WORKFLOWS_SPACE=$(echo "$STAGED_WORKFLOWS" | tr '\n' ' ')
        python3 - <<'PY' $STAGED_WORKFLOWS_SPACE
import sys, yaml, re, os

workflows = sys.argv[1:]

for wf_path in workflows:
    try:
        with open(wf_path, 'r', encoding='utf-8') as f:
            content = f.read()
            # Parse YAML (PyYAML required)
            try:
                import yaml
                data = yaml.safe_load(content) or {}
            except:
                print(f"[WARN] Could not parse YAML: {wf_path}")
                continue

            jobs = data.get('jobs', {})
            for job_name, job in jobs.items():
                # Check concurrency
                if 'concurrency' not in job:
                    print(f"[FAIL] Job '{job_name}' in {wf_path} missing concurrency configuration")
                    # Set global fail but continue checking other jobs
                    globals()['VALIDATION_FAIL'] = 1
                else:
                    concurrency = job['concurrency']
                    if 'cancel-in-progress' not in concurrency or not concurrency['cancel-in-progress']:
                        print(f"[FAIL] Job '{job_name}' in {wf_path} concurrency must have cancel-in-progress: true")
                        globals()['VALIDATION_FAIL'] = 1

                # Check steps for artifact uploads without retention
                steps = job.get('steps', [])
                for step in steps:
                    if step.get('uses') == 'actions/upload-artifact@v4':
                        step_name = step.get('name', 'unnamed step')
                        with_block = step.get('with', {})
                        if 'retention-days' not in with_block:
                            print(f"[FAIL] Step '{step_name}' in job '{job_name}' missing retention-days")
                            globals()['VALIDATION_FAIL'] = 1
    except Exception as e:
        print(f"[WARN] Error validating {wf_path}: {e}")

if globals().get('VALIDATION_FAIL', 0):
    print("\nAdd concurrency to jobs and retention-days: 7 to artifact uploads.")
    sys.exit(1)
PY
        if [ $? -ne 0 ]; then
            FAIL=1
            echo -e "${RED}[FAIL] Workflow validation failed${NC}"
        else
            echo -e "${GREEN}[PASS]${NC}"
        fi
    fi
else
    echo -e "${GREEN}[PASS] (no workflow changes)${NC}"
fi

# 7. Update documentation timestamps
echo -n "  Updating doc timestamps... "
python - <<'PY' 2>/dev/null
import datetime, re, sys
date_str = datetime.date.today().strftime('%Y-%m-%d')
files = ['docs/DEVELOPER.md', 'docs/ARCHITECTURE.md', 'docs/FLYWAY.md', 'docs/MIGRATIONS.md', 'docs/TROUBLESHOOTING.md']
updated = []
for path in files:
    try:
        with open(path, 'r', encoding='utf-8') as f:
            content = f.read()
        if re.search(r'Last (?:updated|Updated):\s+\d{4}-\d{2}-\d{2}', content):
            new_content = re.sub(
                r'(Last\s+(?:updated|Updated):\s+)\d{4}-\d{2}-\d{2}',
                r'\1' + date_str,
                content
            )
            if new_content != content:
                with open(path, 'w', encoding='utf-8') as f:
                    f.write(new_content)
                updated.append(path)
    except: pass
if updated:
    print(f"    Updated: {', '.join(updated)}")
    print("    Please 'git add' these updated docs.")
PY
echo -e "${GREEN}[PASS]${NC}"

# Summary
echo ""
if [ $FAIL -eq 0 ]; then
    echo -e "${GREEN}[PASS] All pre-commit checks passed!${NC}"
    echo "   [PASS] Python syntax, formatting, linting, secrets, TODOs, workflows"
    echo "   (For comprehensive checks: bandit, mypy, smoke test, use pre-push hook)"
    exit 0
else
    echo ""
    echo -e "${RED}[FAIL] Pre-commit checks failed.${NC}"
    echo "   Fix the issues above or use 'git commit --no-verify' to skip (NOT recommended)."
    echo ""
    echo "[TIP] Tip: Install dev tools: pip install flake8 mypy black bandit pyyaml"
    exit 1
fi
