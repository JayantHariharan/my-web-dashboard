#!/bin/bash
set -e

echo "🔍 Running pre-commit quality checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Use ASCII fallbacks on Windows if needed (avoid Unicode errors)
if command -v uname &> /dev/null && uname | grep -i windows &> /dev/null; then
    CHECK_MARK="[PASS]"
    WARN_MARK="[WARN]"
    FAIL_MARK="[FAIL]"
else
    CHECK_MARK="[PASS]"
    WARN_MARK="[WARN]"
    FAIL_MARK="[FAIL]"
fi

FAIL=0

# 1. Python syntax check
echo -n "  Python syntax... "
if python - <<'PY' 2>/dev/null
import ast
from pathlib import Path

for path in Path("src/backend").rglob("*.py"):
    ast.parse(path.read_text(encoding="utf-8"), filename=str(path))
PY
then
    echo -e "${GREEN}[PASS]${NC}"
else
    echo -e "${RED}[FAIL] Syntax error${NC}"
    python - <<'PY' || true
import ast
from pathlib import Path

for path in Path("src/backend").rglob("*.py"):
    try:
        ast.parse(path.read_text(encoding="utf-8"), filename=str(path))
    except SyntaxError as exc:
        print(f"{path}:{exc.lineno}:{exc.offset}: {exc.msg}")
        raise
PY
    FAIL=1
fi

# 2. Hardcoded secrets check (fast pattern match)
echo -n "  Hardcoded secrets... "
if grep -rn "SECRET_KEY\s*=" src/backend/ --include="*.py" \
    | grep -v "os.environ.get" \
    | grep -v "from os import" \
    > /dev/null 2>&1; then
    echo -e "${RED}[FAIL] Potential hardcoded secret${NC}"
    grep -rn "SECRET_KEY\s*=" src/backend/ --include="*.py" \
        | grep -v "os.environ.get" \
        | grep -v "from os import" || true
    FAIL=1
else
    echo -e "${GREEN}[PASS]${NC}"
fi

# 4. Check for TODO/FIXME in committed files
echo -n "  No TODO/FIXME in commits... "
STAGED_TEXT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(py|js|html|css|md|yml|yaml|sh)$' || true)
if [ -n "$STAGED_TEXT_FILES" ]; then
    # Use -w for word match to avoid false positives (e.g., "DEBUG" matching "BUG")
    if echo "$STAGED_TEXT_FILES" | xargs grep -lw -E "TODO|FIXME|BUG|HACK" 2>/dev/null > /dev/null; then
        echo -e "${YELLOW}[WARN] TODO/FIXME found${NC}"
        echo "$STAGED_TEXT_FILES" | xargs grep -nw -E "TODO|FIXME|BUG|HACK" || true
        echo "    Consider addressing or create issue for tracking."
    else
        echo -e "${GREEN}[PASS]${NC}"
    fi
else
    echo -e "${GREEN}[PASS]${NC}"
fi

# 5. Workflow validation (concurrency, retention)
echo -n "  Validating workflow files... "
if command -v python3 &> /dev/null; then
    # Get staged workflow files
    STAGED_WORKFLOWS=$(git diff --cached --name-only --diff-filter=ACM | grep '^\.github/workflows/.*\.yml$' || true)

    if [ -n "$STAGED_WORKFLOWS" ]; then
        VALIDATION_FAIL=0
        # Convert newlines to spaces to pass as separate arguments
        STAGED_WORKFLOWS_SPACE=$(echo "$STAGED_WORKFLOWS" | tr '\n' ' ')
        python3 - <<'PY' $STAGED_WORKFLOWS_SPACE
import sys, yaml, re, os

workflows = sys.argv[1:]

for wf_path in workflows:
    try:
        with open(wf_path, 'r', encoding='utf-8') as f:
            content = f.read()
            # Parse YAML (PyYAML required)
            try:
                import yaml
                data = yaml.safe_load(content) or {}
            except:
                print(f"[WARN] Could not parse YAML: {wf_path}")
                continue

            jobs = data.get('jobs', {})
            workflow_concurrency = data.get('concurrency', {})
            for job_name, job in jobs.items():
                # Check concurrency: job can inherit from workflow level or have its own
                job_concurrency = job.get('concurrency', workflow_concurrency)
                if not job_concurrency:
                    print(f"[FAIL] Job '{job_name}' in {wf_path} missing concurrency configuration (neither job-level nor workflow-level)")
                    globals()['VALIDATION_FAIL'] = 1
                else:
                    if 'cancel-in-progress' not in job_concurrency or not job_concurrency['cancel-in-progress']:
                        print(f"[FAIL] Job '{job_name}' in {wf_path} concurrency must have cancel-in-progress: true")
                        globals()['VALIDATION_FAIL'] = 1

                # Check steps for artifact uploads without retention
                steps = job.get('steps', [])
                for step in steps:
                    if step.get('uses') == 'actions/upload-artifact@v4':
                        step_name = step.get('name', 'unnamed step')
                        with_block = step.get('with', {})
                        if 'retention-days' not in with_block:
                            print(f"[FAIL] Step '{step_name}' in job '{job_name}' missing retention-days")
                            globals()['VALIDATION_FAIL'] = 1
    except Exception as e:
        print(f"[WARN] Error validating {wf_path}: {e}")

if globals().get('VALIDATION_FAIL', 0):
    print("\nAdd concurrency to jobs and retention-days: 7 to artifact uploads.")
    sys.exit(1)
PY
        if [ $? -ne 0 ]; then
            FAIL=1
            echo -e "${RED}[FAIL] Workflow validation failed${NC}"
        else
            echo -e "${GREEN}[PASS]${NC}"
        fi
    fi
else
    echo -e "${GREEN}[PASS] (no workflow changes)${NC}"
fi

# 6. README only (project docs consolidated); optional: bump *Last updated* in README manually
echo -n "  Documentation... "
echo -e "${GREEN}[SKIP]${NC}"

# Summary
echo ""
if [ $FAIL -eq 0 ]; then
    echo -e "${GREEN}[PASS] All pre-commit checks passed!${NC}"
    echo "   [PASS] Python syntax, secrets, TODOs, workflow validation"
    exit 0
else
    echo ""
    echo -e "${RED}[FAIL] Pre-commit checks failed.${NC}"
    echo "   Fix the issues above or use 'git commit --no-verify' to skip (NOT recommended)."
    echo ""
    echo "[TIP] Install dev tool: pip install pyyaml (for YAML workflow validation)"
    exit 1
fi
