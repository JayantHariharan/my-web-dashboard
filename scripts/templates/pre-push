#!/bin/bash
set -e

echo "🚀 Running pre-push quality & security checks..."

# Determine which branch is being pushed
LOCAL_REF=$1
LOCAL_SHA=$2
REMOTE_REF=$3
REMOTE_SHA=$4

# Ensure we're at repository root
cd "$(git rev-parse --show-toplevel)" 2>/dev/null || exit 1

# Clean up unnecessary files before push
echo ""
echo "🧹 Cleaning up unnecessary files..."
bash ./scripts/cleanup-unnecessary.sh

# For feature branches, check if they're up-to-date with origin/develop to avoid merge conflicts
BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)
if [[ "$BRANCH_NAME" =~ ^(main|develop|master)$ ]]; then
    # Main branches get full checks below
    :
elif [[ "$BRANCH_NAME" =~ ^(fmt|feat|fix|chore)/ ]]; then
    echo "🔍 Checking if feature branch is up-to-date with origin/develop..."
    git fetch origin develop >/dev/null 2>&1

    # Check if origin/develop is an ancestor of current HEAD
    if git merge-base --is-ancestor origin/develop HEAD 2>/dev/null; then
        echo "✅ Feature branch includes latest develop changes"
    else
        echo "⚠️  Warning: Your feature branch does NOT include latest changes from develop"
        echo "   This will likely cause merge conflicts when you create a PR."
        echo ""
        echo "To fix this, run:"
        echo "   git fetch origin"
        echo "   git rebase origin/develop"
        echo ""
        echo "Continuing push anyway (you have been warned)..."
        echo ""
    fi
else
    # Not a recognized branch pattern, just continue
    :
fi

echo "📦 Branch: $BRANCH_NAME"
echo ""

# Run comprehensive quality checks
if bash ./scripts/run-quality-checks.sh; then
    echo ""
    echo "✅ Pre-push checks passed!"
    echo "   Your code is secure and meets quality standards."
    exit 0
else
    echo ""
    echo "❌ Pre-push checks failed!"
    echo "   Fix the errors above before pushing."
    echo ""
    echo "💡 You can skip with 'git push --no-verify' but DON'T unless you have a good reason."
    echo "   Skipping checks risks pushing vulnerable or broken code."
    exit 1
fi
